{
  "name": "kimi-debug-tunnel",
  "version": "1.0.0",
  "description": "MCP debug tunnel server with HTTP+WebSocket console for Kimi Code CLI session orchestration",
  "main": "dist/index.js",
  "bin": {
    "kimi-debug-tunnel": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && cp -r src/public/* dist/public/",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "keywords": [
    "mcp",
    "debug",
    "tunnel",
    "kimi-code"
  ],
  "type": "module",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.21.0",
    "js-yaml": "^5.2.1",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.12",
    "typescript": "^5.6.0"
  }
}
